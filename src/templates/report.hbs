         font-family: Roboto, sans-serif;
         font-size: 9px;
         font-style: normal;
         font-weight: 700;
         line-height: 13.5px;
         white-space: nowrap;
      }

      .freebies-list {
         display: grid;
      }

      .freebies-item {
         display: grid;
         grid-template-columns: 52px 1fr 20px;
         gap: 12px;
         align-items: center;
         padding: 11px 0;
         border-bottom: 1px solid rgba(23, 74, 110, 0.65);
      }

      .freebies-item:last-child {
         border-bottom: 0;
      }

      .freebies-thumb {
         width: 52px;
         height: 52px;
         border-radius: 12px;
         border: 1px solid rgba(0, 229, 255, 0.16);
         background-color: #0c2946;
         background-size: cover;
         background-position: center;
         background-repeat: no-repeat;
      }

      .freebies-copy h4 {
         margin: 0;
         color: #fff;
         font-family: Roboto, sans-serif;
         font-size: 11px;
         font-style: normal;
         font-weight: 600;
         line-height: 15.125px;
      }

      .freebies-copy p {
         margin: 4px 0 0;
         color: #7a9bbf;
         font-family: Roboto, sans-serif;
         font-size: 10px;
         font-style: normal;
         font-weight: 400;
         line-height: 13.75px;
      }

      .freebies-check {
         display: inline-flex;
         align-items: center;
         justify-content: center;
      }

      .freebies-unlock-strip {
         margin-top: 11px;
         height: 34px;
         padding: 0 12px;
         border-radius: 12px;
         border: 1px solid rgba(244, 196, 48, 0.15);
         background: rgba(244, 196, 48, 0.06);
         display: flex;
         align-items: center;
         gap: 8px;
      }

      .freebies-unlock-strip span {
         display: inline-flex;
         align-items: center;
         color: #f4c430;
         font-family: Roboto, sans-serif;
         font-size: 10px;
         font-style: normal;
         line-height: 13.75px;
      }

      .freebies-unlock-strip strong {
         font-weight: 700;
      }

      .freebies-unlock-strip em {
         font-style: normal;
         font-weight: 400;
      }

      .freebies-cta-btn {
         margin-top: 12px;
         width: 100%;
         height: 44px;
         border: 0;
         border-radius: 12px;
         background: linear-gradient(97deg, #f4c430 0%, #f59e0b 100%);
         color: #020617;
         text-align: center;
         font-family: Roboto, sans-serif;
         font-size: 12px;
         font-style: normal;
         font-weight: 700;
         line-height: 16px;
         display: inline-flex;
         align-items: center;
         justify-content: center;
         gap: 8px;
         cursor: pointer;
      }

      .freebies-cta-btn svg {
         flex: 0 0 auto;
      }

      /* =========================================================


      .aside-container {
         display: flex;
         flex-direction: column;
         align-items: stretch;
         justify-content: flex-start;
         gap: 20px;
         width: 100%;
         min-width: 0;

      }

      .recommendation-panel,
      .freebies-card,
      .root-cause-section {
         min-width: 0;
         width: 100%;
      }

      /* =========================================================
   Responsive behavior
========================================================= */
      @media (max-width: 1366px) {
         .main-card-title-wrap h3 {
            font-size: 18px;
         }

         .hero-copy h1 {
            font-size: clamp(1.8rem, 3vw, 2.9rem);
         }

         .hero-copy p {
            font-size: 13px;
         }

         .insight-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
         }

         .insight-card {
            width: 100%;
            height: auto;
            min-height: 133px;
         }

         .blue-card {
            min-height: 136px;
         }
      }









      /* =========================================================
   Legal Notice Section
========================================================= */
      .legal-notice-section {
         /* width: 819.1875px; */
         max-width: 100%;
         height: auto;
         /* Allow header + grid to fit */
         margin: 40px auto 0;
         padding-bottom: 20px;
         opacity: 1;
      }

      /* Force Lifestyle Risk Breakdown to start on a new page */
      .lifestyle-risk-section {
         page-break-before: always !important;
         break-before: page !important;
      }

      .legal-notice-header {
         display: flex;
         align-items: center;
         gap: 12px;
         margin-bottom: 16px;
         padding-bottom: 12px;
         border-bottom: 1px solid rgba(159, 180, 208, 0.1);
      }

      .legal-notice-header h3 {
         font-family: Roboto, sans-serif;
         font-size: 16px;
         font-weight: 700;
         color: #fff;
         margin: 0;
         letter-spacing: 0.5px;
      }

      .legal-icon-wrap {
         width: 24px;
         height: 24px;
         background: rgba(243, 182, 63, 0.12);
         border-radius: 6px;
         display: flex;
         align-items: center;
         justify-content: center;
         color: #f3b63f;
      }

      .legal-notice-grid {
         display: grid;
         grid-template-columns: repeat(2, 1fr);
         column-gap: 12px;
         row-gap: 12px;
         width: 100%;
      }

      .legal-card {
         height: 106px;
         background: #061A2E;
         border: 1px solid #054358;
         border-radius: 16px;
         padding: 17px;
         display: flex;
         flex-direction: column;
         gap: 8px;
         box-sizing: border-box;
         opacity: 1;
      }

      .legal-card-head {
         display: flex;
         align-items: center;
         gap: 12px;
      }

      .legal-card-icon {
         width: 32px;
         height: 32px;
         border-radius: 50%;
         display: flex;
         align-items: center;
         justify-content: center;
         flex-shrink: 0;
      }

      .legal-card-head h4 {
         font-family: 'Roboto', sans-serif !important;
         font-size: 10px !important;
         font-weight: 600 !important;
         color: rgba(107, 133, 160, 1) !important;
         margin: 0;
         line-height: 15px !important;
      }

      .legal-card:first-child .legal-card-body {
         opacity: 1;
      }

      .legal-card-body {
         margin: 0;
         opacity: 0.85;
      }

      .icon-red {
         background: rgba(239, 68, 68, 0.08);
         color: #ef4444 !important;
         border: 1px solid rgba(239, 68, 68, 0.15);
      }

      .icon-yellow {
         background: rgba(243, 182, 63, 0.08);
         color: #f3b63f !important;
         border: 1px solid rgba(243, 182, 63, 0.15);
      }

      .icon-cyan {
         background: rgba(0, 229, 255, 0.08);
         color: #00e5ff !important;
         border: 1px solid rgba(0, 229, 255, 0.15);
      }

      .icon-purple {
         background: rgba(168, 85, 247, 0.08);
         color: #a855f7 !important;
         border: 1px solid rgba(168, 85, 247, 0.15);
      }


      .legal-card * {
         font-family: 'Roboto', sans-serif !important;
         font-weight: 400 !important;
         font-style: normal !important;
         font-size: 8px !important;
         line-height: 12px !important;
         letter-spacing: 0px !important;
         vertical-align: middle !important;
         color: rgba(107, 133, 160, 1) !important;
      }

      /* =========================================================
   Additional responsive safeguards (tablet + mobile only)
========================================================= */





      /* =========================================================
   CRITICAL: 320px Screen Fixes - MUST BE LAST FOR PROPER CASCADE
   This media query is placed at the END of the file to ensure
   it overrides all other responsive styles for 320px screens
========================================================= */



      /* =========================================================
   PRINT / PDF SPECIFIC STYLES - DO NOT MODIFY UI
   ========================================================= */
      @media print {
         @page {
            size: A4 portrait;
            margin: 0px !important;
            padding: 10 !important;
         }

         * {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
            color-adjust: exact !important;
         }

         body {
            background-color: #020617 !important;
            margin: 0 !important;
            padding: 0 !important;
         }

         .report-page-screen {
            background: #020617 !important;
            min-height: 100% !important;
         }

         /* Prevent breaking mid-way for cards and sections */
         .report-diagnostic-panel,
         .medical-review-card,
         .medical-card-body,
         .score-dashboard-wrap,
         .score-main-card,
         .score-side-card,
         .score-side-col,
         .clinical-dashboard,
         .clinical-dimension-grid,
         .clinical-dimension-card,
         .clinical-severity-row,
         .ai-photo-analysis-section,
         .ai-photo-analysis-card,
         .ai-photo-grid,
         .ai-photo-tile,
         .ai-analysis-insights-card,
         .ai-analysis-insight-row,
         .ai-questionnaire-correlation-card,
         .ai-photo-metrics-grid,
         .ai-photo-metric-card,
         .ai-photo-security-note,
         .deep-metric-section,
         .deep-metric-card,
         .deep-metric-panels,
         .deep-metric-panel,
         .deep-metric-meaning-row,
         .regional-analysis-section,
         .regional-analysis-card,
         .regional-analysis-body,
         .root-cause-section,
         .root-cause-card,
         .scalp-recovery-section,
         .insight-card,
         .clinical-insight-card,
         .side-product-card,
         .review-stat-box,
         .meal-plan-section,
         .deep-metric-section,
         .review-stats-row {
            page-break-inside: avoid !important;
            break-inside: avoid !important;
            margin-top: 20px !important;
         }

         /* Sections that must start on a new page */
         .lifestyle-risk-section,
         .legal-notice-section {
            page-break-before: always !important;
            break-before: page !important;
         }

         /* Progress Bars Stability Fix (Flexbox for Print) */
         .predictive-risk-row {
            display: flex !important;
            align-items: center !important;
            gap: 12px !important;
            width: 100% !important;
         }

         .predictive-risk-label {
            width: 50px !important;
            flex-shrink: 0 !important;
         }

         .predictive-risk-bars {
            flex: 1 1 auto !important;
            display: flex !important;
            flex-direction: column !important;
            gap: 4px !important;
         }

         .predictive-risk-track {
            height: 10px !important;
            background-color: #041126 !important;
            border-radius: 5px !important;
            position: relative !important;
            width: 100% !important;
            overflow: hidden !important;
         }

         .predictive-risk-fill {
            height: 10px !important;
            position: absolute !important;
            left: 0 !important;
            top: 0 !important;
            border-radius: 50px !important;
         }

         .predictive-risk-fill-red {
            background-color: #ef4444 !important;
            box-shadow: inset 0 0 0 1000px #ef4444 !important;
         }

         .predictive-risk-fill-green {
            background-color: #10b981 !important;
            box-shadow: inset 0 0 0 1000px #10b981 !important;
         }

         /* Foods to Avoid Grid fix */
         .avoid-habits-grid {
            display: flex !important;
            flex-wrap: wrap !important;
            gap: 10px !important;
         }

         .avoid-habit-card {
            width: calc(50% - 5px) !important;
            background-color: #041126 !important;
            box-shadow: inset 0 0 0 1000px #041126 !important;
            border-radius: 8px !important;
         }

         /* Headers */
         h1,
         h2,
         h3,
         h4,
         h5 {
            page-break-after: avoid !important;
            break-after: avoid !important;
         }

         img,
         svg {
            max-width: 100% !important;
         }
      }
   </style>

</head>

